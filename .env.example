# Copy to .env and fill in. Never commit .env.

# Mapillary developer token: https://www.mapillary.com/developer
MAPILLARY_ACCESS_TOKEN=

# Cloudflare R2 (S3-compatible). Zero egress fees are what make the
# imagery proxy affordable; see docs/adr/0002-imagery-proxy.md
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=terraquest-imagery

DB_URL=jdbc:postgresql://localhost:5432/terraquest
DB_USER=terraquest
DB_PASSWORD=local_dev_only

REDIS_HOST=localhost
REDIS_PORT=6379
