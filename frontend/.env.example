# Copy to .env to override. All optional -- the defaults work for local dev.

# Basemap style for the guess map. Default is OpenFreeMap (keyless, full OSM
# detail, no signup). MapLibre's demo tiles are a zero-dependency fallback:
#   https://demotiles.maplibre.org/style.json
VITE_MAP_STYLE=https://tiles.openfreemap.org/styles/liberty

# API base path. Default '/api/v1' is proxied to the backend by the Vite dev
# server (see vite.config.ts). Point this at an absolute URL for a non-proxied
# deployment.
VITE_API_BASE=/api/v1

# Where the backend's LocalFilesystemStorageProvider wrote images. Defaults to
# <os-tmpdir>/terraquest-imagery, which matches the backend default. Only set
# this if you pointed the backend at a custom LOCAL_STORAGE_DIR.
# LOCAL_STORAGE_DIR=

# Backend origin the Vite dev server proxies /api to. Default http://localhost:8080.
# VITE_API_PROXY_TARGET=http://localhost:8080
